function y = h_tdoa2(t, x, u, th)

% Distances to each sensor
d1 = sqrt((x(1,:) - th(1)).^2 + (x(2,:) - th(2)).^2);
d2 = sqrt((x(1,:) - th(3)).^2 + (x(2,:) - th(4)).^2);
d3 = sqrt((x(1,:) - th(5)).^2 + (x(2,:) - th(6)).^2);
d4 = sqrt((x(1,:) - th(7)).^2 + (x(2,:) - th(8)).^2);

% TDOA measurements (relative to sensor 1)
y = [
    d1 - d2;
    d1 - d3;
    d1 - d4
];

end